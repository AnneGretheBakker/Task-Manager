{#
  Template: task/_delete_form.html.twig
  Purpose: Renders a Symfony form for deleting a Task entity.
  Expected variables:
    - form: Symfony FormView object for TaskType
#}
<form method="post" action="{{ path('app_task_delete', {'id': task.id}) }}" onsubmit="return confirm('Are you sure you want to delete this item?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ task.id) }}">
    <button class="actionButton">Delete</button>
</form>

{#
  Template: task/show.html.twig
  Purpose: Show the task the user clicked on, with the options to go back, edit or delete the task.
  Extends: base.html.twig
  Variables expected:
    - task: Task entity, with the following properties:
        - id: int
        - title: string
        - description: string|null
        - deadline: \DateTimeInterface|null
        - status: string ('Open', 'Doing' or 'Done')
        - priority: string ('Low', 'Medium' or 'High')
#}
{% extends 'base.html.twig' %}

{% block title %}Show task{% endblock %}

{% block body %}
    <div class='tasksDiv'>
        <h1>Task</h1>

        <table class="table">
            <tbody>
                <tr>
                    <th>Title</th>
                    <td>{{ task.title }}</td>
                </tr>
                <tr>
                    <th>Description</th>
                    <td>{{ task.description }}</td>
                </tr>
                <tr>
                    <th>Deadline</th>
                    {# Only format date if it's not null, else show empty string #}
                    <td>{{ task.deadline ? task.deadline|date('Y-m-d H:i:s') : '' }}</td>
                </tr>
                <tr>
                    <th>Status</th>
                    <td>{{ task.status }}</td>
                </tr>
                <tr>
                    <th>Priority</th>
                    <td>{{ task.priority }}</td>
                </tr>
                <tr>
                    <td colspan="2">
                        <a href="{{ path('app_task_index') }}" class='actionButton'>back to list</a>
                        <a href="{{ path('app_task_edit', {'id': task.id}) }}" class='actionButton'>edit</a>
                        {# Delete button #}
                        {{ include('task/_delete_form.html.twig') }}
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    {% block stylesheets %}
        <link rel="stylesheet" href="{{ asset('/styles/css/task.css') }}">
    {% endblock %}
{% endblock %}

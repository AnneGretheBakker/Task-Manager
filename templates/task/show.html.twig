{% extends 'base.html.twig' %}

{% block title %}Task{% endblock %}

{% block body %}
    <div class='tasksDiv'>
        <h1>Task</h1>

        <table class="table">
            <tbody>
                <tr>
                    <th>Title</th>
                    <td>{{ task.title }}</td>
                </tr>
                <tr>
                    <th>Description</th>
                    <td>{{ task.description }}</td>
                </tr>
                <tr>
                    <th>Deadline</th>
                    <td>{{ task.deadline ? task.deadline|date('Y-m-d H:i:s') : '' }}</td>
                </tr>
                <tr>
                    <th>Status</th>
                    <td>{{ task.status }}</td>
                </tr>
                <tr>
                    <th>Priority</th>
                    <td>{{ task.priority }}</td>
                </tr>
                <tr>
                    <th>
                        <a href="{{ path('app_task_index') }}" class='actionButton'>back to list</a>
                        <a href="{{ path('app_task_edit', {'id': task.id}) }}" class='actionButton'>edit</a>
                        {{ include('task/_delete_form.html.twig') }}
                    </th>
                    <td> </td>
                </tr>
            </tbody>
        </table>
    </div>

    {% block stylesheets %}
        <link rel="stylesheet" href="{{ asset('/styles/css/task.css') }}">
    {% endblock %}
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Log in!{% endblock %}

{% block body %}
<div class='loginDiv'>
    <form method="post">
        {% if error %}
            <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}

        {% if app.user %}
            <div class="mb-3">
                You are logged in as {{ app.user.userIdentifier }}, <a href="{{ logout_path() }}">Logout</a>
            </div>
        {% endif %}

        <h1 class="h3 mb-3 font-weight-normal">Please sign in</h1>
        <table id='loginTable'>
            <tr>
                <th>Email</th>
                <td>
                    <input type="email" value="{{ last_username }}" name="email" id="inputEmail" class="form-control"
                    autocomplete="email" required autofocus>
                </td>
            </tr>
            <tr>
                <th>Password</th>
                <td>
                    <input type="password" name="password" id="inputPassword" class="form-control"
                        autocomplete="current-password" required>
                    <input type="hidden" name="_csrf_token" data-controller="csrf-protection"
                        value="{{ csrf_token('authenticate') }}">
                </td>
            </tr>
            <tr>
                <th>
                    <button class="actionButton" type="submit">Sign in</button>
                </th>
                <td> </td>
            </tr>
        </table>
    </form>
</div>

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('/styles/css/task.css') }}">
{% endblock %}
{% endblock %}
